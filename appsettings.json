  "Search": {
    "DefaultMaxResults": 5,
    "MinMaxResults": 1,
    "MaxMaxResults": 20
  },
  "WebRead": {
    "DefaultMaxLength": 8000
  },
  "Terminal": {
    "DefaultTimeoutSeconds": 60,
    "MinTimeoutSeconds": 1,
    "MaxTimeoutSeconds": 300,
    "MaxOutputChars": 6000
  }
