{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Click": "Warning",
      "Click.Agents.Common.Tools": "Warning",
      "Click.Infrastructure": "Warning",
      "System.Net.Http.HttpClient": "Error"
    },
    "Console": {
      "LogLevel": {
        "Default": "Information",
        "Click": "Warning",
        "Click.Agents.Common.Tools": "Warning",
        "Click.Infrastructure": "Warning",
        "System.Net.Http.HttpClient": "Error"
      }
    }
  },
  "Click": {
    "BasePath": "D:/ClickProjects"
  },
  "OpenAi": {
    "BaseUrl": "",
    "ApiKey": "",
    "Model": "groq/openai/gpt-oss-120b",
    "RequestTimeoutSeconds": 60
  },
  "Serper": {
    "ApiKey": ""
  },
  "Agent": {
    "MaxIterations": 2000,
    "MaxToolResultCharsKeep": 2500,
    "MaxToolResultCharsSuccess": 400,
